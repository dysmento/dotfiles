if status is-interactive
    # Commands to run in interactive sessions can go here
end
set -x REDFIN_MAIN {$HOME}/code/main
set -x REDFIN_NPM  {$HOME}/code/redfin-npm
set -x REDFIN_GLOBAL_DEVCONTAINERS_ENV_FILE /usr/local/redfin/devcontainers/global.env
set -x REDFIN_DATA_SECURE /usr/local/redfin/data/secure
set -x DEFAULT_KAFKA_SSL_TRUSTSTORE_LOCATION /usr/local/redfin/data/secure/ssl/default.kafka.client.truststore.jks
if test -e /usr/local/redfin/data/secure/ssl/default.truststore.password
  set -x DEFAULT_KAFKA_SSL_TRUSTSTORE_PASSWORD (cat /usr/local/redfin/data/secure/ssl/default.truststore.password)
end
set -x CONFLUENT_HOME {$HOME}/confluent-{{ .confluentVersion }}
{{ if .brewhome -}}
set -x PATH {$HOME}/n/bin {{ .brewhome }}/bin {$HOME}/code/fin/bin {$CONFLUENT_HOME}/bin {$HOME}/bin {$HOME}/.local/bin $PATH {{ .brewhome }}/opt/postgresql@16/bin {$HOME}/infra/bin
{{- else -}}
set -x PATH {$HOME}/code/fin/bin {$CONFLUENT_HOME}/bin {$HOME}/.local/bin $PATH
{{- end }}
set -x LC_ALL en_US.UTF-8
starship init fish | source

set -x CLAUDE_CODE_NEW_INIT 1
set -x ANTHROPIC_MODEL sonnet

set -x JAVA_HOME (mise where java)

test -e {$HOME}/.iterm2_shell_integration.fish ; and source {$HOME}/.iterm2_shell_integration.fish

fzf --fish | source

alias ls='eza'
alias tree='lsd --tree'
alias corvair=$REDFIN_MAIN/bin/corvair

ulimit -n 65536

