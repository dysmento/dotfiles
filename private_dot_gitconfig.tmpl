[user]
	name = {{ .name | quote }}
	email = {{ .email }}
	signingkey = ssh-rsa 
[gpg]
	format = ssh
[gpg "ssh"]
	program = {{ .passwordSigningProgram | quote }}
	allowedSignersFile = {{ .chezmoi.homeDir }}/.config/git/allowed_signers
[commit]
	gpgsign = true
[pull]
	rebase = true
[core]
	excludesfile = {{ .chezmoi.homeDir }}/.gitignore_global
[includeIf "gitdir:{{ .chezmoi.homeDir }}/rent-corp/"]
	path = {{ .chezmoi.homeDir }}/rent-corp/.gitconfig
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper = 
	helper = {{ .chezmoi.homeDir }}/.local/share/mise/shims/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = {{ .chezmoi.homeDir }}/.local/share/mise/shims/gh auth git-credential
